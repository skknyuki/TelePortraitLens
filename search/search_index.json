{"config":{"lang":["en"],"separator":"[\\s\\-]+","pipeline":["stopWordFilter"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"TelePortraitLens","text":""},{"location":"#whats-this-camera","title":"What's this Camera?","text":"<p>Tele Portrait Lens \u306f\u3001VRChat \u30a2\u30d0\u30bf\u30fc\u5411\u3051\u306e\u30ab\u30e1\u30e9\u30ae\u30df\u30c3\u30af\u3067\u3059\u3002 \u30dd\u30fc\u30c8\u30ec\u30fc\u30c8\u64ae\u5f71\u3092\u3057\u3084\u3059\u304f\u3059\u308b\u3053\u3068 \u3092\u4e3b\u76ee\u7684\u3068\u3057\u3066\u5236\u4f5c\u3055\u308c\u3066\u3044\u307e\u3059\u3002</p> <p>\u672c\u30ae\u30df\u30c3\u30af\u3067\u306f\u30013\u3064\u306e\u30ab\u30e1\u30e9\u3092\u4f7f\u7528\u3057\u3066 \u524d\u666f\uff08Fore\uff09\u3001\u30e1\u30a4\u30f3\u3001\u80cc\u666f\uff08Back\uff09 \u3092\u305d\u308c\u305e\u308c\u500b\u5225\u306b\u64ae\u5f71\u3057\u3001 \u305d\u306e\u5834\u3067\u5408\u6210\u3057\u3066\u3044\u307e\u3059\u3002</p> <p>\u307e\u305f\u3001\u524d\u666f \u3068 \u80cc\u666f \u306b\u306f\u5f37\u5236\u7684\u306b\u307c\u304b\u3057\u304c\u9069\u7528\u3055\u308c\u307e\u3059\u3002 \u3053\u308c\u306b\u3088\u308a\u3001\u901a\u5e38\u306e\u30ab\u30e1\u30e9\u3067\u306f\u307c\u304b\u3057\u306b\u304f\u3044 \u30a8\u30d5\u30a7\u30af\u30c8 \u3084 \u30d1\u30fc\u30c6\u30a3\u30af\u30eb \u3082\u3001 \u81ea\u7136\u306b\u307c\u304b\u3057\u3066\u8868\u73fe\u3067\u304d\u307e\u3059\u3002</p> <p>\u3055\u3089\u306b\u30013\u3064\u306e\u30ab\u30e1\u30e9\u306f\u305d\u308c\u305e\u308c\u500b\u5225\u306b\u5236\u5fa1\u3067\u304d\u307e\u3059\u3002 \u305d\u306e\u305f\u3081\u3001\u305f\u3068\u3048\u3070 \u80cc\u666f\u3060\u3051\u753b\u89d2\u3092\u5909\u3048\u308b\u3001 \u524d\u666f\u3092 Screen \u5408\u6210\u3057\u3066\u6c34\u9762\u8868\u73fe\u3092\u52a0\u3048\u308b \u3068\u3044\u3063\u305f\u6f14\u51fa\u3082\u53ef\u80fd\u3067\u3059\u3002</p>"},{"location":"faq/","title":"FAQ","text":"<p>\u30ab\u30e1\u30e9\u3092\u4e09\u3064\u4f7f\u7528\u3057\u3066\u3044\u308b \u666e\u901a\u3067\u306f\u306a\u3044 \u4ed5\u69d8\u306e\u305f\u3081\u3001 \u5236\u9650\u304c\u3068\u3066\u3082\u3042\u308a\u307e\u3059\u306e\u3067\u3054\u4e86\u627f\u304f\u3060\u3055\u3044\u3002</p> <ul> <li>\u30ef\u30fc\u30eb\u30c9\u306b\u3088\u3063\u3066\u306f\u3001\u3046\u307e\u304f\u64ae\u308c\u306a\u3044\u3068\u3053\u308d\u3082\u3042\u308a\u307e\u3059\u3002</li> <li>\u8996\u754c\u30cf\u30c3\u30af\u30a8\u30d5\u30a7\u30af\u30c8\u304c\u3042\u308b\u30ef\u30fc\u30eb\u30c9\u3067\u306f\u3001\u3061\u3083\u3093\u3068\u64ae\u308c\u306a\u3044\u3067\u3059\u3002</li> <li>\u8a66\u7528\u3055\u308c\u3066\u3044\u308b\u30b7\u30a7\u30fc\u30c0\u30fc\u306b\u3088\u3063\u3066\u306f\u304d\u3061\u3093\u3068\u64ae\u308c\u306a\u3044\u3067\u3059\u3002</li> <li>\u30c9\u30ed\u30fc\u30f3\u6a5f\u80fd\u306f\u30e1\u30a4\u30f3\u30ab\u30e1\u30e9\u306b\u3057\u304b\u4f7f\u3048\u307e\u305b\u3093\u3002</li> </ul>"},{"location":"history/","title":"History","text":""},{"location":"history/#260430","title":"26/04/30","text":"<pre><code>\u8ca9\u58f2\u958b\u59cb\n</code></pre>"},{"location":"howtouse/","title":"How to Use","text":""},{"location":"howtouse/#_1","title":"\u4f7f\u3044\u65b9","text":"<p>VRC\u30cf\u30f3\u30c9\u30ab\u30e1\u30e9\u3092\u51fa\u3057\u3001 \u30a8\u30af\u30b9\u30d7\u30ec\u30c3\u30b7\u30e7\u30f3\u30e1\u30cb\u30e5\u30fc\u304b\u3089[TelePortraitLens]\u3092\u9078\u629e [TelePortrait ON]\u3092\u9078\u629e\u3059\u308b\u3068\u3001\u30ec\u30f3\u30ba\u304c\u8d77\u52d5\u3057\u307e\u3059\u3002 </p> <p>\u3053\u306e\u30ab\u30e1\u30e9\u30aa\u30d6\u30b8\u30a7\u306fVR\u753b\u9762\u4e0a\u304b\u3089\u3057\u304b\u898b\u308c\u307e\u305b\u3093\u3002 \u307e\u305f\u4ed6\u306e\u4eba\u304b\u3089\u3082\u898b\u3048\u307e\u305b\u3093\u3002 </p>"},{"location":"howtouse/#_2","title":"\u57fa\u672c\u7684\u306a\u64ae\u308a\u65b9","text":"<ol> <li>\u30ab\u30e1\u30e9\u3092\u8d77\u52d5\u3057\u305f\u3089\u3001[Lens]-[Focus Range]\u3092\u9078\u629e\u3001\u88ab\u5199\u4f53\u3068\u306e\u8ddd\u96e2\u306b\u8fd1\u3044\u6570\u5024\u3092\u9078\u3076\u3002</li> <li>[Lens]-[Focus]\u3092\u9078\u629e\u3001\u4e0a\u4e0b\u30dc\u30bf\u30f3\u3067\u88ab\u5199\u4f53\u306b\u30e1\u30a4\u30f3\u30ab\u30e1\u30e9\u306e\u64ae\u5f71\u7bc4\u56f2\u3092\u5408\u308f\u305b\u308b\u3002 \u5de6\u53f3\u3067\u3001\u30d5\u30a9\u30fc\u30ab\u30b9\u7bc4\u56f2\u3092\u5e83\u3052\u308b\u3053\u3068\u304c\u53ef\u80fd\u3067\u3059\u3002(\u21d0:\u7bc4\u56f2\u62e1\u5927 / \u21d2:\u7bc4\u56f2\u7e2e\u5c0f)</li> <li>[Lens]-[FOV]-[Main Fov]\u3067\u753b\u89d2\u3092\u5408\u308f\u305b\u3088\u3046\u3002</li> </ol>"},{"location":"howtouse/#_3","title":"\u7570\u5e38\u306a\u64ae\u308a\u65b9","text":"<ul> <li>[Lens]-[FOV] \u3067Fore\u3068Back\u306e\u753b\u89d2\u3092 \u305d\u308c\u305e\u308c \u5909\u66f4\u3067\u304d\u307e\u3059\u3002</li> <li>[Lens]-[Unit]\u3000\u3067\u3001\uff13\u3064\u306e\u30ab\u30e1\u30e9\u306e\u8a2d\u5b9a\u3092\u305d\u308c\u305e\u308c\u5909\u66f4\u3067\u304d\u307e\u3059\u3002</li> <li> <p>[Lens]-[Unit]-[Fore]-[LayerBlend]\u3067\u524d\u666f\u306e\u7d75\u3092Photoshop\u306e\u3088\u3046\u306a\u30ec\u30a4\u30e4\u30fc\u30d6\u30ec\u30f3\u30c9\u3092\u9078\u3079\u307e\u3059\u3002 \u3053\u308c\u306b\u3088\u308a\u3001\u524d\u666f\u30ab\u30e1\u30e9\u3060\u3051WorldFix\u3067\u5225\u306e\u5834\u6240\u3092\u5199\u3057\u3066\u30b9\u30af\u30ea\u30fc\u30f3\u3067\u91cd\u306d\u305f\u308a\u3067\u304d\u307e\u3059\u3002  </p> </li> <li> <p>\u4f8b\u3048\u3070\u3001\u982d\u4e0a\u306b\u5927\u304d\u306a\u6e80\u6708\u304c\u3042\u308b\u30ef\u30fc\u30eb\u30c9\u306b\u3066\u3001\u30e1\u30a4\u30f3\u30ab\u30e1\u30e9\u306b\u3066\u6b63\u9762\u304b\u3089\u4eba\u3092\u5199\u3057\u3064\u3064 \u80cc\u666f\u30ab\u30e1\u30e9\u3092\u982d\u4e0a\u306e\u5927\u304d\u306a\u6e80\u6708\u306b\u5411\u3051\u3066WorldFix\u3092\u3057\u3066\u64ae\u308b\u3002 \u3059\u308b\u3068\u4eba\u7269\u306e\u5f8c\u308d\u306b\u6e80\u6708\u304c\u5b58\u5728\u3057\u3066\u3044\u308b\u5199\u771f\u304c\u64ae\u308c\u307e\u3059\u3002  </p> </li> </ul>"},{"location":"howtouse/#_4","title":"\u4ed5\u69d8","text":"<ul> <li>\u30ef\u30fc\u30eb\u30c9\u306b\u3088\u3063\u3066\u306f\u3001\u3046\u307e\u304f\u64ae\u308c\u306a\u3044\u3068\u3053\u308d\u3082\u3042\u308a\u307e\u3059\u3002</li> <li>\u8996\u754c\u30cf\u30c3\u30af\u30a8\u30d5\u30a7\u30af\u30c8\u304c\u3042\u308b\u30ef\u30fc\u30eb\u30c9\u3067\u306f\u3001\u3061\u3083\u3093\u3068\u64ae\u308c\u306a\u3044\u3067\u3059\u3002</li> <li>\u8a66\u7528\u3055\u308c\u3066\u3044\u308b\u30b7\u30a7\u30fc\u30c0\u30fc\u306b\u3088\u3063\u3066\u306f\u304d\u3061\u3093\u3068\u64ae\u308c\u306a\u3044\u3067\u3059\u3002</li> <li>\u30c9\u30ed\u30fc\u30f3\u6a5f\u80fd\u306f\u30e1\u30a4\u30f3\u30ab\u30e1\u30e9\u306b\u3057\u304b\u4f7f\u3048\u307e\u305b\u3093\u3002</li> </ul>"},{"location":"install/","title":"\u5c0e\u5165\u65b9\u6cd5","text":"<ol> <li>Modular Avatar \u3092\u5c0e\u5165\u3057\u3066\u304f\u3060\u3055\u3044\u3002 \u6700\u65b0\u7248\u306e Modular Avatar \u306e\u4f7f\u7528\u3092\u63a8\u5968\u3057\u307e\u3059\u3002 \u30d0\u30fc\u30b8\u30e7\u30f3\u304c\u53e4\u3044\u5834\u5408\u3001\u6b63\u5e38\u306b\u52d5\u4f5c\u3057\u306a\u3044\u3053\u3068\u3084\u30a8\u30e9\u30fc\u304c\u767a\u751f\u3059\u308b\u3053\u3068\u304c\u3042\u308a\u307e\u3059\u3002   Modular Avatar \u306e\u5c0e\u5165\u306f\u3053\u3061\u3089 </li> <li>Prefab \u3092\u30a2\u30d0\u30bf\u30fc\u76f4\u4e0b\u306b\u914d\u7f6e\u3057\u3066\u304f\u3060\u3055\u3044\u3002 \u53f3\u5229\u304d\u306e\u65b9\u306f [TelePortraitLens] \u3092\u4f7f\u7528\u3057\u3066\u304f\u3060\u3055\u3044\u3002 \u5de6\u5229\u304d\u306e\u65b9\u306f [TelePortraitLens_Left] \u3092\u914d\u7f6e\u3057\u3066\u304f\u3060\u3055\u3044\u3002 </li> <li>\u30a2\u30c3\u30d7\u30ed\u30fc\u30c9\u5f8c\u3001Expressions Menu \u306b [TelePortraitLens] \u304c\u8ffd\u52a0\u3055\u308c\u307e\u3059\u3002 </li> </ol>"},{"location":"optional1/","title":"\u64ae\u5f71\u30af\u30aa\u30ea\u30c6\u30a3\u8a2d\u5b9a","text":"<p>\u30c7\u30d5\u30a9\u30eb\u30c8\u3067\u306f\u3001\u64ae\u5f71\u30af\u30aa\u30ea\u30c6\u30a3\u306f 4K \u306b\u8a2d\u5b9a\u3055\u308c\u3066\u3044\u307e\u3059\u3002 \u89e3\u50cf\u5ea6\u3092\u5909\u66f4\u3057\u305f\u3044\u5834\u5408\u306f\u3001RenderTexture \u306e Size \u3092\u5909\u66f4\u3057\u3066\u304f\u3060\u3055\u3044\u3002</p> <p>RenderTexture \u306f\u3001\u4ee5\u4e0b\u306e\u30d5\u30a9\u30eb\u30c0\u5185\u306b\u3042\u308a\u307e\u3059\u3002</p> <p><code>[GoatCannery]/[TelePortraitLens]/[Textures]/[RenderTexture]</code></p>"},{"location":"optional1/#rendertexture","title":"\u5404 RenderTexture \u306e\u5f79\u5272","text":"<ul> <li> <p>\"TPL_Main\"   \u30e1\u30a4\u30f3\u306e\u88ab\u5199\u4f53\u3092\u64ae\u5f71\u3059\u308b\u30ab\u30e1\u30e9\u3067\u3059\u3002   \u3053\u306e\u89e3\u50cf\u5ea6\u3092\u3001\u4fdd\u5b58\u3057\u305f\u3044\u5199\u771f\u306e\u89e3\u50cf\u5ea6\u306b\u5408\u308f\u305b\u3066\u8a2d\u5b9a\u3057\u3066\u304f\u3060\u3055\u3044\u3002</p> </li> <li> <p>\u305d\u308c\u4ee5\u5916\u306e\u30c6\u30af\u30b9\u30c1\u30e3 \"TPL_Back\", \"TPL_Fore\", \"TPL_Fore_depth\"   \u3053\u308c\u3089\u306f \"TPL_Main\" \u306e\u534a\u5206\u306e\u89e3\u50cf\u5ea6 \u306b\u8a2d\u5b9a\u3057\u3066\u304f\u3060\u3055\u3044\u3002</p> </li> </ul>"},{"location":"optional1/#_2","title":"\u63a8\u5968\u89e3\u50cf\u5ea6","text":"\u30c6\u30af\u30b9\u30c1\u30e3\u540d \u30d5\u30ebHD QHD 4K\uff08\u30c7\u30d5\u30a9\u30eb\u30c8\uff09 8K TPL_Main 1920x1080 2560x1440 3840x2160 7680x4320 \u305d\u308c\u4ee5\u5916 960x540 1280x720 1920x1080 3840x2160"},{"location":"optional1/#anti-aliasing","title":"Anti-aliasing \u306b\u3064\u3044\u3066","text":"<p>\"TPL_Main\" \u306e Anti-aliasing \u3092\u4e0a\u3052\u308b\u3068\u3001\u5199\u771f\u306e\u54c1\u8cea\u306f\u5411\u4e0a\u3057\u307e\u3059\u3002 \u305f\u3060\u3057\u3001\u305d\u306e\u5206 VRChat \u306e\u8ca0\u8377\u3082\u5927\u304d\u304f\u306a\u308b \u305f\u3081\u3001 \u81ea\u8eab\u306ePC\u30b9\u30da\u30c3\u30af\u3068\u76f8\u8ac7\u3057\u306a\u304c\u3089\u8a2d\u5b9a\u3057\u3066\u304f\u3060\u3055\u3044\u3002 \u521d\u671f\u8a2d\u5b9a\u306f [2 samples]\u306b\u306a\u3063\u3066\u304a\u308a\u307e\u3059\u3002</p>"},{"location":"optional1/#_3","title":"\u88dc\u8db3","text":"<p>\"TPL_Back\", \"TPL_Fore\", \"TPL_Fore_depth\" \u306e\u89e3\u50cf\u5ea6\u3092\u4e0a\u3052\u3066\u3082\u3001 \u5185\u90e8\u3067\u306f \u534a\u5206\u306e\u89e3\u50cf\u5ea6\u3067\u51e6\u7406 \u3057\u3001\u6700\u7d42\u7684\u306b\u30dc\u30b1\u3055\u305b\u308b\u305f\u3081\u3001 \u5fc5\u8981\u4ee5\u4e0a\u306b\u9ad8\u3044\u89e3\u50cf\u5ea6\u3078\u8a2d\u5b9a\u3059\u308b\u3053\u3068\u306f\u304a\u3059\u3059\u3081\u3057\u307e\u305b\u3093\u3002</p> <p>\u6ce8 HD(720P)\u30b5\u30a4\u30ba\u306b\u306f\u5bfe\u5fdc\u3057\u3066\u304a\u308a\u307e\u305b\u3093\u3002 \uff08\u30a2\u30a4\u30b3\u30f3\u3084\u30b0\u30ea\u30c3\u30c9\u304c\u8868\u793a\u3055\u308c\u3066\u3057\u307e\u3044\u307e\u3059\uff09</p>"},{"location":"menu/Drone/","title":"Drone","text":"<p>\u30ec\u30f3\u30ba\u3092\u30c9\u30ed\u30fc\u30f3\u306e\u3088\u3046\u306b\u64cd\u4f5c\u3057\u3066\u79fb\u52d5\u3055\u305b\u308b\u6a5f\u80fd\u3067\u3059\u3002</p> <p></p>"},{"location":"menu/Drone/#drone_1","title":"Drone","text":"<p>\u30c9\u30ed\u30fc\u30f3\u30e2\u30fc\u30c9\u3092\u8d77\u52d5\u3057\u307e\u3059\u3002 \u5229\u304d\u624b\u3068\u9006\u306e\u624b \u3067\u30c9\u30ed\u30fc\u30f3\u3092\u79fb\u52d5\u3057\u3001\u5229\u304d\u624b \u3067\u30ab\u30e1\u30e9\u306e\u5411\u304d\u3092\u64cd\u4f5c\u3067\u304d\u307e\u3059\u3002</p> <p>\u30c9\u30ed\u30fc\u30f3\u30e2\u30fc\u30c9\u3092\u7d42\u4e86\u3059\u308b\u3068\u3001\u30ec\u30f3\u30ba\u306f\u305d\u306e\u6642\u70b9\u306e\u4f4d\u7f6e\u3067\u56fa\u5b9a\u3055\u308c\u307e\u3059\u3002</p>"},{"location":"menu/Drone/#_1","title":"\u64cd\u4f5c\u65b9\u6cd5","text":"<p>\u8d77\u52d5\u5f8c\u306f\u3001\u30b9\u30c6\u30a3\u30c3\u30af\u64cd\u4f5c\u3067\u4ee5\u4e0b\u306e\u3088\u3046\u306b\u52d5\u4f5c\u3057\u307e\u3059\u3002</p> <ul> <li>\u5de6\u53f3\u5165\u529b \uff1a\u30ab\u30e1\u30e9\u3092\u5de6\u53f3\u306b\u56de\u8ee2\u3057\u307e\u3059</li> <li>\u4e0a\u4e0b\u5165\u529b\u4e2d \uff1a\u30c9\u30ed\u30fc\u30f3\u306e\u79fb\u52d5\u901f\u5ea6\u304c\u4e0a\u304c\u308a\u307e\u3059</li> </ul>"},{"location":"menu/Drone/#drone-rotate-only","title":"Drone (Rotate Only)","text":"<p>\u30c9\u30ed\u30fc\u30f3\u3092\u79fb\u52d5\u3055\u305b\u305a\u3001\u30ab\u30e1\u30e9\u306e\u5411\u304d\u306e\u307f\u3092 \u5229\u304d\u624b \u3067\u64cd\u4f5c\u3067\u304d\u307e\u3059\u3002</p>"},{"location":"menu/Drone/#main-fov","title":"Main Fov","text":"<p>\u30e1\u30a4\u30f3\u30ab\u30e1\u30e9\u306e FOV \u3092\u8abf\u6574\u3067\u304d\u307e\u3059\u3002 [Sync] \u304c ON \u306e\u5834\u5408\u306f\u3001\u4ed6\u306e\u30ab\u30e1\u30e9\u306e FOV \u306b\u3082\u540c\u671f\u3055\u308c\u307e\u3059\u3002</p>"},{"location":"menu/Drone/#auto-level","title":"Auto Level","text":"<p>\u30ab\u30e1\u30e9\u306e\u50be\u304d\u3092\u5236\u5fa1\u3057\u307e\u3059\u3002 \u30ab\u30e1\u30e9\u306e\u50be\u304d\u3092 \u5de6\u30fb\u6b63\u9762\u30fb\u53f3 \u306b\u56fa\u5b9a\u3067\u304d\u307e\u3059\u3002</p>"},{"location":"menu/Drone/#worldfix-drone-reset","title":"WorldFix (Drone Reset)","text":"<p>\u30c9\u30ed\u30fc\u30f3\u3092\u624b\u5143\u306e\u4f4d\u7f6e\u306b\u623b\u3057\u307e\u3059\u3002\u3000\u3000 \u3082\u3057\u304f\u306f\u7a7a\u4e2d\u306b\u56fa\u5b9a\u3067\u304d\u307e\u3059</p>"},{"location":"menu/Lens/","title":"Lens","text":""},{"location":"menu/Lens/#optics","title":"Optics","text":"<p>\u30ab\u30e1\u30e9\u306e\u8996\u91ce\u89d2\u3084\u30dc\u30b1\u306e\u5f37\u3055\u3092\u5909\u66f4\u3067\u304d\u307e\u3059\u3002 FOV\u306e\u8a2d\u5b9a\u7bc4\u56f2\u306f 12mm \uff5e 1000mm \u76f8\u5f53\u3067\u3059\u3002</p> <ul> <li>0% \uff1a12mm</li> <li>25% \uff1a53mm</li> <li>50% \uff1a94mm</li> <li>75% \uff1a135mm</li> <li>100% \uff1a1000mm</li> </ul> <p></p> <ul> <li> <p>[Main Fov]   \u30e1\u30a4\u30f3\u30ab\u30e1\u30e9\u306e FOV \u3092\u5909\u66f4\u3067\u304d\u307e\u3059\u3002</p> </li> <li> <p>[Sync]   ON \u72b6\u614b\u3067\u306f\u3001\u30e1\u30a4\u30f3\u30ab\u30e1\u30e9\u306e FOV \u3068\u540c\u671f\u3057\u307e\u3059\u3002</p> </li> <li> <p>[Fov [Fore]] / [Fov [Back]]   \u3053\u308c\u3089\u3092\u9078\u629e\u3059\u308b\u3068\u3001\u5bfe\u5fdc\u3059\u308b [Sync] \u306f\u81ea\u52d5\u7684\u306b OFF \u306b\u306a\u308a\u307e\u3059\u3002</p> </li> <li> <p>[Bokeh [Fore]] / [Bokeh [Back]]   \u30dc\u30b1\u306e\u5f37\u3055\u3092\u5909\u66f4\u3057\u307e\u3059\u3002</p> </li> </ul>"},{"location":"menu/Lens/#back-main-fore","title":"Back / Main / Fore","text":""},{"location":"menu/Lens/#_1","title":"\u5171\u901a\u8a2d\u5b9a","text":""},{"location":"menu/Lens/#cc","title":"CC","text":"<p>\u5404\u30ab\u30e1\u30e9\u3067\u753b\u50cf\u88dc\u6b63\u304c\u51fa\u6765\u307e\u3059\u3002 </p> <ul> <li>Exposure : \u9732\u51fa</li> <li>Contrast : \u30b3\u30f3\u30c8\u30e9\u30b9\u30c8</li> <li>Tone Curve : \u30c8\u30fc\u30f3\u30ab\u30fc\u30d6</li> <li>Natural Saturation : \u81ea\u7136\u306a\u5f69\u5ea6</li> <li>Saturation : \u5f69\u5ea6</li> </ul> <p></p>"},{"location":"menu/Lens/#worldfix","title":"WorldFix","text":"<p>\u5404\u30ab\u30e1\u30e9\u3092\u30ef\u30fc\u30eb\u30c9\u306b\u56fa\u5b9a\u3067\u304d\u307e\u3059\u3002</p> <p></p> <ul> <li>Return \uff1a \u30e1\u30a4\u30f3\u30ab\u30e1\u30e9\u306e\u4f4d\u7f6e\u306b\u623b\u308a\u307e\u3059\u3002</li> <li>WorldFix \uff1a \u30ab\u30e1\u30e9\u3092\u30ef\u30fc\u30eb\u30c9\u306b\u56fa\u5b9a\u3057\u307e\u3059\u3002</li> <li>Hand \uff1a \u30ab\u30e1\u30e9\u3092\u624b\u5143\u3068\u540c\u671f\u3057\u307e\u3059\u3002</li> </ul> <p></p>"},{"location":"menu/Lens/#autolevel","title":"AutoLevel","text":"<p>\u5404\u30ab\u30e1\u30e9\u306e\u50be\u304d\u3092 \u5de6\u30fb\u6b63\u9762\u30fb\u53f3 \u306b\u56fa\u5b9a\u3067\u304d\u307e\u3059\u3002</p>"},{"location":"menu/Lens/#back","title":"Back","text":""},{"location":"menu/Lens/#clip-adjust","title":"Clip Adjust","text":"<p>Back \u30ab\u30e1\u30e9\u306e Far \u306e\u4f4d\u7f6e\u3092\u3001\u624b\u524d\u5074\u306b\u5fae\u8abf\u6574\u3067\u304d\u307e\u3059\u3002</p>"},{"location":"menu/Lens/#main","title":"Main","text":""},{"location":"menu/Lens/#show-ui-layer","title":"Show UI Layer","text":"<p>ON \u306b\u3059\u308b\u3068\u3001UI Layer \u3092\u63cf\u753b\u3067\u304d\u307e\u3059\u3002(\u30e1\u30a4\u30f3\u306e\u307f)</p> <p></p>"},{"location":"menu/Lens/#far-cliping","title":"Far Cliping","text":"<p>ON \u306b\u3059\u308b\u3068\u3001Main\u30ab\u30e1\u30e9\u306e Far \u304c Back\u30ab\u30e1\u30e9\u306e Far \u3068\u540c\u3058\u306b\u306a\u308a\u307e\u3059\u3002 Back\u30ab\u30e1\u30e9\u3067\u9060\u666f\u307e\u3067\u542b\u3081\u3066\u3001\u753b\u9762\u5168\u4f53\u3092\u5199\u305b\u308b\u3088\u3046\u306b\u306a\u308a\u307e\u3059\u3002</p>"},{"location":"menu/Lens/#fore","title":"Fore","text":""},{"location":"menu/Lens/#layerblend","title":"LayerBlend","text":"<p>\u524d\u666f\u306e\u5408\u6210\u30e2\u30fc\u30c9\u3092\u9078\u629e\u3067\u304d\u307e\u3059\u3002</p> <p></p> <ul> <li>None \uff1a\u524d\u666f\u3092\u63cf\u753b\u3057\u307e\u305b\u3093</li> <li>Add \uff1a\u52a0\u7b97</li> <li>Dodge \uff1a\u8986\u3044\u713c\u304d\u30ab\u30e9\u30fc</li> <li>Normal \uff1a\u901a\u5e38\u5408\u6210</li> <li>Screen \uff1a\u30b9\u30af\u30ea\u30fc\u30f3</li> <li> <p>Multiply \uff1a\u4e57\u7b97</p> </li> <li> <p>Alfa \uff1a\u524d\u666f\u306e\u900f\u660e\u5ea6\u3092\u5909\u66f4\u3067\u304d\u307e\u3059</p> </li> </ul>"},{"location":"menu/Lens/#_2","title":"\u88dc\u8db3","text":"<ul> <li>Normal\u4ee5\u5916 \u3092\u9078\u629e\u3057\u305f\u5834\u5408\u3001\u30e1\u30a4\u30f3\u30ab\u30e1\u30e9\u306e Far \u306f Fore \u30ab\u30e1\u30e9\u306e Far \u3068\u540c\u3058\u306b\u306a\u308a\u307e\u3059\u3002</li> <li>Normal \u3067\u306f\u900f\u660e\u5ea6\u3092\u5909\u66f4\u3067\u304d\u307e\u305b\u3093\u3002</li> <li>Normal \u9078\u629e\u6642\u306f\u3001Depth \u304c\u3042\u308b\u90e8\u5206\u306f\u5f8c\u65b9\u3092\u4e0a\u66f8\u304d\u3057\u3001Depth \u304c\u306a\u3044\u90e8\u5206\u306f Screen \u5408\u6210\u3055\u308c\u307e\u3059\u3002</li> </ul>"},{"location":"menu/Lens/#clip-adjust_1","title":"clip Adjust","text":"<p>Fore \u30ab\u30e1\u30e9\u306e Far \u306e\u4f4d\u7f6e\u3092\u3001\u5965\u5074\u3078\u5fae\u8abf\u6574\u3067\u304d\u307e\u3059\u3002</p> <p></p>"},{"location":"menu/Lens/#clipping-far-range","title":"Clipping Far Range","text":"<p>ON \u306b\u3059\u308b\u3068\u3001Fore\u30ab\u30e1\u30e9\u306e Far \u304c Back\u30ab\u30e1\u30e9\u306e Far \u3068\u540c\u3058\u306b\u306a\u308a\u307e\u3059\u3002 Fore\u30ab\u30e1\u30e9\u3067\u9060\u666f\u307e\u3067\u542b\u3081\u3066\u3001\u753b\u9762\u5168\u4f53\u3092\u5199\u305b\u308b\u3088\u3046\u306b\u306a\u308a\u307e\u3059\u3002</p>"},{"location":"menu/Lens/#focus","title":"Focus","text":"<p>\u30d4\u30f3\u30c8\u3092\u5408\u308f\u305b\u308b\u8ddd\u96e2\u3068\u3001\u30d4\u30f3\u30c8\u304c\u5408\u3046\u7bc4\u56f2\u3092\u8abf\u6574\u3067\u304d\u307e\u3059\u3002</p> <ul> <li>\u2191 / Farther\uff1a\u30d5\u30a9\u30fc\u30ab\u30b9\u8ddd\u96e2\u3092\u5965\u3078\u79fb\u52d5</li> <li>\u2193 / Closer \uff1a\u30d5\u30a9\u30fc\u30ab\u30b9\u8ddd\u96e2\u3092\u624b\u524d\u3078\u79fb\u52d5</li> <li>\u2190 / Widen\uff1a\u30d5\u30a9\u30fc\u30ab\u30b9\u7bc4\u56f2\u3092\u5e83\u3052\u308b</li> <li>\u2192 / Narrow\uff1a\u30d5\u30a9\u30fc\u30ab\u30b9\u7bc4\u56f2\u3092\u72ed\u304f\u3059\u308b</li> </ul> <p></p>"},{"location":"menu/Lens/#focus-range","title":"Focus Range","text":"<p>\u30d5\u30a9\u30fc\u30ab\u30b9\u8ddd\u96e2\u3092\u3001\u4e00\u5b9a\u306e\u8ddd\u96e2\u304b\u3089\u9078\u629e\u3067\u304d\u307e\u3059\u3002 \u30d5\u30a9\u30fc\u30ab\u30b9\u7bc4\u56f2\u306f \u7d04 1.5m \u306b\u306a\u308a\u307e\u3059\u3002</p>"},{"location":"menu/Lens/#autofocus","title":"AutoFocus","text":"<p>VRCRaycast\u3092\u4f7f\u7528\u3057\u3066\u3001\u30ab\u30e1\u30e9\u306e\u4e2d\u5fc3\u90e8\u5206\u306b\u3042\u308b \u30b3\u30e9\u30a4\u30c0\u30fc \u306b\u30d5\u30a9\u30fc\u30ab\u30b9\u3092\u5408\u308f\u305b\u307e\u3059\u3002 VRChat\u306e\u4ed5\u69d8\u306b\u3088\u308a\u3001\u81ea\u8eab\u304b\u30ef\u30fc\u30eb\u30c9\u306e\u30b3\u30e9\u30a4\u30c0\u30fc\u306b\u3057\u304b\u53cd\u5fdc\u3057\u307e\u305b\u3093\u3002</p> <ul> <li>AF_DoF \u306fAF\u5f8c\u306e\u30d5\u30a9\u30fc\u30ab\u30b9\u7bc4\u56f2\u3092\u3042\u308b\u7a0b\u5ea6\u306b\u8a2d\u5b9a\u3067\u304d\u307e\u3059\u3002</li> </ul>"},{"location":"menu/Preset/","title":"Preset","text":""},{"location":"menu/Preset/#reset","title":"Reset","text":""},{"location":"menu/Setting/","title":"Setting","text":""},{"location":"menu/Setting/#grid","title":"Grid","text":"<p>\u30d7\u30ec\u30d3\u30e5\u30fc\u753b\u9762\u306b\u30b0\u30ea\u30c3\u30c9\u3092\u8868\u793a\u3067\u304d\u307e\u3059\u3002\u64ae\u5f71\u3057\u305f\u5199\u771f\u306b\u306f\u5199\u308a\u307e\u305b\u3093\u3002  \u4f7f\u7528\u3057\u305f\u3044\u30b0\u30ea\u30c3\u30c9\u3092\u9078\u629e\u3057\u3066\u304f\u3060\u3055\u3044\u3002  </p>"},{"location":"menu/Setting/#far-clipping-back","title":"Far Clipping [Back]","text":"<p>Back\u30ab\u30e1\u30e9\u306e\u8868\u793a\u53ef\u80fd\u8ddd\u96e2\u3092\u8abf\u6574\u3067\u304d\u307e\u3059\u3002 Skybox \u304c\u6620\u3089\u306a\u3044\u5834\u5408\u3084\u3001\u9060\u65b9\u306e\u30aa\u30d6\u30b8\u30a7\u30af\u30c8\u304c\u8868\u793a\u3055\u308c\u306a\u3044\u5834\u5408\u306f\u3001\u3053\u306e\u5024\u3092\u5927\u304d\u304f\u3057\u3066\u304f\u3060\u3055\u3044\u3002</p> <ul> <li>0% \uff1a1km</li> <li>50% \uff1a10km</li> <li>75% \uff1a25km</li> <li>100% \uff1a1000km</li> </ul>"},{"location":"menu/Setting/#aspect-ratio","title":"Aspect Ratio","text":"<p>\u6307\u5b9a\u3057\u305f\u30a2\u30b9\u30da\u30af\u30c8\u6bd4\u3067\u5199\u771f\u3092\u64ae\u5f71\u3067\u304d\u307e\u3059\u3002 \u30d5\u30ec\u30fc\u30e0\u306e\u5916\u5074\u306f\u9ed2\u3067\u8868\u793a\u3055\u308c\u307e\u3059\u3002[White Back] \u3092 ON \u306b\u3059\u308b\u3068\u3001\u767d\u3067\u8868\u793a\u3055\u308c\u307e\u3059\u3002</p> <p></p> <p>\u9078\u629e\u3067\u304d\u308b\u30a2\u30b9\u30da\u30af\u30c8\u6bd4\u306f\u4ee5\u4e0b\u306e\u901a\u308a\u3067\u3059\u3002</p> <ul> <li>16:9</li> <li>Square (1:1)</li> <li>3:2</li> <li>4:3</li> <li>\u30b7\u30cd\u30b9\u30b3 (2.35:1)</li> <li>Silver Ratio\uff08\u9ec4\u91d1\u6bd4\uff09</li> </ul>"},{"location":"menu/Setting/#frame-white","title":"Frame White","text":"<p>ON \u306b\u3059\u308b\u3068\u3001\u30d5\u30ec\u30fc\u30e0\u304c\u767d\u306b\u306a\u308a\u307e\u3059\u3002</p>"},{"location":"menu/Setting/#capture-a-frame","title":"Capture a Frame","text":"<p>\u30d5\u30ec\u30fc\u30e0\u3092\u64ae\u3063\u305f\u5199\u771f\u306b\u5199\u3059\u304b\u3069\u3046\u304b\u3092\u5207\u308a\u66ff\u3048\u307e\u3059\u3002 </p> <p>\u6ce81 \u30ef\u30fc\u30eb\u30c9\u306e Post Effects \u306e\u8a2d\u5b9a\u306b\u3088\u3063\u3066\u306f\u3001\u9ed2\u3044\u30d5\u30ec\u30fc\u30e0\u90e8\u5206\u306b\u30a8\u30d5\u30a7\u30af\u30c8\u304c\u304b\u304b\u308b\u5834\u5408\u304c\u3042\u308a\u307e\u3059\u3002 \u307e\u305f\u3001\u30d5\u30ec\u30fc\u30e0\u3092\u767d\u306b\u3057\u305f\u5834\u5408\u306f\u3001\u5199\u771f\u5185\u90e8\u306b\u30a8\u30d5\u30a7\u30af\u30c8\u304c\u304b\u304b\u308b\u5834\u5408\u304c\u3042\u308a\u307e\u3059\u3002</p> <p>\u6ce82 \u30d5\u30ec\u30fc\u30e0\u3092\u767d\u304f\u3057\u305f\u72b6\u614b\u3067 VRC+ \u306e\u30d7\u30ea\u30f3\u30c8\u6a5f\u80fd\u3092\u4f7f\u7528\u3057\u305f\u5834\u5408\u3001 \u30d7\u30ea\u30f3\u30c8\u3055\u308c\u305f\u5199\u771f\u306e\u5916\u5074\u306e\u767d\u3068\u3001\u5199\u771f\u5185\u90e8\u306e\u767d\u306f\u7570\u306a\u308b\u8272\u306b\u306a\u308a\u307e\u3059\u3002 \u3053\u308c\u306f\u4ed5\u69d8\u3067\u3059\u3002</p>"},{"location":"menu/Setting/#maxbriightness","title":"MaxBriightness","text":"<p>\u5143\u306e\u5149\u304c\u6975\u7aef\u306b\u5f37\u3044\u5834\u5408\u3001\u307c\u304b\u3057\u90e8\u5206\u306b\u30ce\u30a4\u30ba\u304c\u5165\u308b\u3053\u3068\u304c\u3042\u308a\u307e\u3059\u3002 \u305d\u306e\u5834\u5408\u306f\u3001\u3053\u306e\u5024\u3092\u4e0b\u3052\u3066\u8abf\u6574\u3057\u3066\u304f\u3060\u3055\u3044\u3002</p>"},{"location":"menu/Setting/#lens-transform-adjust","title":"Lens Transform Adjust","text":""},{"location":"menu/Setting/#posison-adjust","title":"Posison Adjust","text":"<p>\u30ec\u30f3\u30ba\u306e\u4f4d\u7f6e\u3092\u5de6\u53f3\u65b9\u5411\u306b\u5fae\u8abf\u6574\u3067\u304d\u307e\u3059\u3002</p>"},{"location":"menu/Setting/#rotate-adjust","title":"Rotate Adjust","text":"<p>\u30ec\u30f3\u30ba\u306e\u56de\u8ee2\u3092\u4e0a\u4e0b\u65b9\u5411\u306b\u5fae\u8abf\u6574\u3067\u304d\u307e\u3059\u3002</p>"},{"location":"menu/menu/","title":"Menu TOP","text":""},{"location":"menu/menu/#teleportrait-on","title":"TelePortrait ON","text":"<p>TelePortraitLens\u3092\u8d77\u52d5\u3057\u307e\u3059</p>"},{"location":"menu/menu/#lens","title":"Lens","text":"<p>\u30ab\u30e1\u30e9\u306e\u52d5\u4f5c\u3092\u5909\u66f4\u3067\u304d\u307e\u3059</p>"},{"location":"menu/menu/#preset","title":"Preset","text":"<p>\u5199\u308a\u65b9\u306e\u30d7\u30ea\u30bb\u30c3\u30c8\u3092\u9078\u3079\u307e\u3059 \u307e\u305f\u8a2d\u5b9a\u3092\u521d\u671f\u5316\u3059\u308b\u30ea\u30bb\u30c3\u30c8\u3082\u3042\u308a\u307e\u3059</p>"},{"location":"menu/menu/#drone","title":"Drone","text":"<p>\u30ab\u30e1\u30e9\u3092\u30c9\u30ed\u30fc\u30f3\u3067\u98db\u3070\u305b\u307e\u3059</p>"},{"location":"menu/menu/#worldfix","title":"WorldFix","text":"<p>\u30c9\u30ed\u30fc\u30f3\u3092\u7a7a\u4e2d\u306b\u56fa\u5b9a\u3067\u304d\u307e\u3059\u3002</p>"},{"location":"menu/menu/#setting","title":"Setting","text":"<p>\u30ab\u30e1\u30e9\u306e\u8a2d\u5b9a\u3092\u5909\u66f4\u3067\u304d\u307e\u3059</p>"}]}